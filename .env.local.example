# Supabase (voir README.md pour la procédure complète de setup)
# Project Settings → API, dans le projet Supabase ciblé (dev en local, prod
# en production — ne jamais utiliser la même valeur dans les deux, ni
# exposer la service role key côté client).
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=xxxxx

# Estimation loyer via Gemini + recherche Google (palier gratuit, clé sur
# aistudio.google.com/apikey — pas de carte bancaire requise)
GEMINI_API_KEY=xxxxx
